    <body>

        <div class="AitsContainer">
            <!-- Overlay for closing menu when clicking outside -->
            <div class="AitsOverlay" id="OverlayAITS"></div>

            <!-- Settings Button -->
            <button class="Settings-buttonAITS" id="SettingsButtonAITS">
                <i class="fas fa-cog"></i>
            </button>

            <!-- Settings Menu -->
            <div class="Settings-menuAITS" id="SettingsMenuAITS">
                <div class="Menu-headerAITS">
                    <h2>Settings</h2>
                    <button class="Close-btnAITS" id="CloseButtonAITS">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <div class="SettingBoxScrollAITS">
                    <div class="Setting-groupAITS">
                        <button id="DarkmodetoggleAITS">🌙Dark Mode</button>
                        <div class="Setting-optionAITS">
                            <label class="Setting-labelAITS" for="ThemeColorSelectAITS">Theme</label><br />
                            <select id="ThemeColorSelectAITS" class="Thems-selectAITS">
                                <option value="default">Default</option>
                                
                            </select>
                        </div>
                        <div class="Setting-optionAITS">
                            <label class="Setting-labelAITS" for="FontfamilySelectAITS">Font Family:</label>
                            <select id="FontfamilySelectAITS" class="Thems-selectAITS">
                                <option value="'Inter', sans-serif">Inter</option>
                                <option value="'Roboto', sans-serif">Roboto</option>
                                <option value="'Open Sans', sans-serif">Open Sans</option>
                                <option value="'Montserrat', sans-serif">Montserrat</option>
                                <option value="'Lato', sans-serif">Lato</option>
                                <option value="'Poppins', sans-serif">Poppins</option>
                                <option value="'Merriweather', serif">Merriweather</option>
                                <option value="'Source Sans Pro', sans-serif">Source Sans Pro</option>
                                <option value="'Raleway', sans-serif">Raleway</option>
                                <option value="'Georgia', serif">Georgia (System)</option>
                                <option value="'Arial', sans-serif">Arial (System)</option>
                            </select>
                        </div>
                        <div class="Setting-optionAITS">
                            <label for="font-size">Font Size:</label>
                            <input type="range" id="FontsizeAITS" min="12" max="24" value="14">
                            <span class="float-end" id="FontsizevalueAITS">14px</span>
                        </div>
                        <div class="Setting-optionAITS">
                            <label class="Setting-labelAITS" for="Font-weightAITS">Font Weight:</label>
                            <select id="FontweightAITS" class="Thems-selectAITS">
                                <option value="300" selected>Light (300)</option>
                                <option value="400">Normal (400)</option>
                                <option value="500">Medium (500)</option>
                                <option value="600">Semi-Bold (600)</option>
                                <option value="700">Bold (700)</option>
                                <option value="800">Bolder (800)</option>
                                <option value="900">Boldest (900)</option>
                            </select>
                        </div>

                        <div class="Setting-optionAITS">
                            <label for="line-height">Line Height:</label>
                            <input type="range" id="LineheightAITS" min="1.2" max="2.5" step="0.1" value="1.4">
                            <span class="float-end" id="LineheightvalueAITS">1.4</span>
                        </div>

                        <div class="Button-groupAITS">
                            <button id="ResetbtnAITS" class="BtnAITS Btn-primaryAITS hvr-back-pulse">Reset to Default</button>
                            <button id="SavebtnAITS" class="BtnAITS Btn-primaryAITS hvr-back-pulse">Save Preferences</button>
                        </div>

                        <div class="PresetsAITS">
                            <h3>Quick Presets:</h3>
                            <div class="Preset-buttonsAITS">
                                <button class="Preset-btnAITS" data-font="'Inter', sans-serif" data-size="16"
                                        data-weight="400">
                                    Default
                                </button>
                                <button class="Preset-btnAITS" data-font="'Open Sans', sans-serif" data-size="18" data-weight="400">
                                    High Readability
                                </button>
                                <button class="Preset-btnAITS" data-font="'Merriweather', serif" data-size="17"
                                        data-weight="400">
                                    Classic Reading
                                </button>
                                <button class="Preset-btnAITS" data-font="'Montserrat', sans-serif" data-size="16"
                                        data-weight="600">
                                    Modern Bold
                                </button>
                                <button class="Preset-btnAITS" data-font="'Roboto', sans-serif" data-size="15" data-weight="300">
                                    Light UI
                                </button>
                            </div>
                        </div>
                        <div class="Size-toggleAITS">
                            <button class="Size-btnAITS" data-action="decrease">A-</button>
                            <button class="Size-btnAITS" data-action="reset">A</button>
                            <button class="Size-btnAITS" data-action="increase">A+</button>
                        </div>

                    </div>
                </div>
            </div>


