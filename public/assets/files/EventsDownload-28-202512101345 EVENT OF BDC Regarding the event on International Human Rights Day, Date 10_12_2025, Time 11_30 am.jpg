<script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

<script type="text/javascript">
    let mybutton1 = document.getElementById("googleTranslate");

    function toggleClassAndFunctions() {
        const element = document.getElementById('googleTranslate');
        element.classList.toggle('active');
        if (element.classList.contains('active')) {
            showGT();
        } else {
            hideGt();
        }
    }

    const elements = document.getElementById('google_translate_element');
    function showGT() {
        elements.style.display = "block";
        elements.style.width = "260px";

    }

    function hideGt() {
        elements.style.display = "none";
        elements.style.width = "60px";
    }

    google_translate_element.addEventListener("change", hideGt);
    function hideGt() {
        google_translate_element.style.display = "none";
        googleTranslate.style.width = "60px";
    }

    window.onblur = function () {
        document.getElementById("myDialog").close();
    }

    function ShowDialog() {
        document.getElementById("myDialog").showModal();
    }

    //to google Translate js part

    function googleTranslateElementInit() {
        new google.translate.TranslateElement(
            { pageLanguage: 'en' },
            'google_translate_element'
        );
    }

    $(function () {
        var navbar = $('.header-inner');
        $(window).scroll(function () {
            if ($(window).scrollTop() <= 365.1) {
                navbar.removeClass('navbar-scroll');
            } else {
                navbar.addClass('navbar-scroll');
            }
        });
    });

